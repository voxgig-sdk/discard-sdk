{
  "openapi": "3.0.3",
  "info": {
    "title": "DISCARD API",
    "description": "DISCARD API is a fast and reliable REST API platform built with Go, designed to facilitate seamless interactions for developers. It supports multiple endpoint methods like GET, POST, and more, ensuring high performance and usability for various applications.",
    "version": "1.0.0",
    "contact": {
      "name": "DISCARD API Documentation",
      "url": "https://discardapi.dpdns.org"
    }
  },
  "servers": [
    {
      "url": "https://discardapi.dpdns.org",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "AI Chat",
      "description": "AI Chat related endpoints"
    },
    {
      "name": "Testing",
      "description": "Testing and debugging endpoints"
    }
  ],
  "paths": {
    "/api/test": {
      "get": {
        "tags": [
          "Testing"
        ],
        "summary": "Test GET endpoint",
        "description": "A test endpoint for GET requests to verify API connectivity and response",
        "operationId": "testGet",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "GET request successful"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Testing"
        ],
        "summary": "Test POST endpoint",
        "description": "A test endpoint for POST requests with JSON body",
        "operationId": "testPost",
        "requestBody": {
          "description": "Request body for POST test",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Test message"
                  },
                  "data": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "POST request successful"
                    },
                    "received": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Testing"
        ],
        "summary": "Test PUT endpoint",
        "description": "A test endpoint for PUT requests with JSON body",
        "operationId": "testPut",
        "requestBody": {
          "description": "Request body for PUT test",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "example": "123"
                  },
                  "data": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "PUT request successful"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Testing"
        ],
        "summary": "Test PATCH endpoint",
        "description": "A test endpoint for PATCH requests with JSON body",
        "operationId": "testPatch",
        "requestBody": {
          "description": "Request body for PATCH test",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "example": "123"
                  },
                  "updates": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "PATCH request successful"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Testing"
        ],
        "summary": "Test DELETE endpoint",
        "description": "A test endpoint for DELETE requests",
        "operationId": "testDelete",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "ID of the resource to delete",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "DELETE request successful"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/upload": {
      "post": {
        "tags": [
          "Testing"
        ],
        "summary": "File upload endpoint",
        "description": "Upload a file to the API for testing file upload functionality",
        "operationId": "uploadFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  },
                  "description": {
                    "type": "string",
                    "description": "Optional description of the file"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "File uploaded successfully"
                    },
                    "filename": {
                      "type": "string",
                      "example": "example.txt"
                    },
                    "size": {
                      "type": "integer",
                      "example": 1024
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid file",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "tags": [
          "AI Chat"
        ],
        "summary": "AI Chat endpoint",
        "description": "Send a message to the AI chat service and receive a response",
        "operationId": "aiChat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "The message to send to the AI",
                    "example": "Hello, how are you?"
                  },
                  "context": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": {
                          "type": "string",
                          "enum": [
                            "user",
                            "assistant"
                          ],
                          "example": "user"
                        },
                        "content": {
                          "type": "string",
                          "example": "Previous message"
                        }
                      }
                    },
                    "description": "Optional conversation context"
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful AI response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "response": {
                      "type": "string",
                      "example": "I'm doing well, thank you for asking!"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics": {
      "get": {
        "tags": [
          "Testing"
        ],
        "summary": "Get analytics data",
        "description": "Retrieve analytics and usage statistics for API endpoints",
        "operationId": "getAnalytics",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "description": "Time period for analytics (day, week, month)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "day",
                "week",
                "month"
              ],
              "default": "day"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total_requests": {
                          "type": "integer",
                          "example": 1250
                        },
                        "active_endpoints": {
                          "type": "integer",
                          "example": 5
                        },
                        "inactive_endpoints": {
                          "type": "integer",
                          "example": 0
                        },
                        "period": {
                          "type": "string",
                          "example": "day"
                        }
                      }
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2006-01-02 15:04:05"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string",
            "example": "An error occurred"
          },
          "code": {
            "type": "integer",
            "example": 400
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2006-01-02 15:04:05"
          }
        }
      }
    }
  }
}
